<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <OutputPath>..\..\bin\</OutputPath>
    <UseWPF>true</UseWPF>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <DocumentationFile>..\..\bin\Tailviewer.Api.XML</DocumentationFile>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    
    <!-- Assembly Signing -->
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\sig\key.snk</AssemblyOriginatorKeyFile>
    
    <!-- Disable auto-generated assembly attributes -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    
    <!-- COM -->
    <ComVisible>false</ComVisible>
    <Guid>0c18b216-9ff4-4dcf-88c0-4b1448892f43</Guid>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="log4net" Version="2.0.12" />
    <PackageReference Include="System.Threading.Extensions" Version="2.0.72" />
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\GlobalAssemblyInfo.cs" Link="Properties\GlobalAssemblyInfo.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="app.config" />
    <None Include="Tailviewer.Api.nuspec" />
  </ItemGroup>

</Project>
