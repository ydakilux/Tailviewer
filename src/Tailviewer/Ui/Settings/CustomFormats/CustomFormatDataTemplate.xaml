<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Tailviewer.Ui.Settings.CustomFormats">

    <DataTemplate DataType="{x:Type local:CustomFormatViewModel}"
                  x:Key="CustomFormatDataTemplate">
        <Grid Margin="8,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="200"
                     Margin="0,0,8,0" />
            <ComboBox Grid.Column="1"
                      Margin="0,0,8,0"
                      ItemsSource="{Binding Encodings}"
                      SelectedItem="{Binding Encoding}"/>
            <TextBox Text="{Binding Format, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                     Grid.Column="2" />
            <Button Grid.Column="3" Command="{Binding RemoveCommand}">
                <TextBlock Text="🗑" />
            </Button>

        </Grid>
    </DataTemplate>

</ResourceDictionary>
