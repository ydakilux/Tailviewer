<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:quickFilter="clr-namespace:Tailviewer.Ui.QuickFilter"
                    xmlns:tailviewerControls="clr-namespace:Tailviewer.Ui.Controls"
                    xmlns:ui="clr-namespace:Tailviewer.Ui"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Themes/Constants.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Themes/Converters.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Ui/QuickFilter/FilterToggleButton.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Ui/QuickFilterMatchTypeToggleButton.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate DataType="{x:Type quickFilter:QuickFilterViewModel}">
        <Grid Margin="8,4,0,4" TextElement.Foreground="Black">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Grid Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                    <ColumnDefinition Width="26" />
                    <ColumnDefinition Width="26" />
                    <ColumnDefinition Width="8" />
                </Grid.ColumnDefinitions>

                <CheckBox
                    x:Name="PART_IsActive"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0"
                    IsChecked="{Binding IsActive}"
                    IsEnabled="{Binding CanBeActivated}" />

                <quickFilter:FilterToggleButton x:Name="PART_InvertFilter"
                                                Grid.Column="1"
                                                Width="24"
                                                Height="24"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"
                                                IsChecked="{Binding IsInverted, Mode=TwoWay}" />

                <TextBox
                    x:Name="PART_Value"
                    Grid.Column="2"
                    Height="26"
                    AcceptsTab="True"
                    Text="{Binding Value, Mode=TwoWay, NotifyOnSourceUpdated=True}"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    Padding="4,2"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center" />

                <ToggleButton
                    SnapsToDevicePixels="True"
                    x:Name="PART_EditToggleButton"
                    Grid.Column="3"
                    VerticalAlignment="Center"
                    IsChecked="{Binding IsEditing, Mode=TwoWay}"
                    Width="26"
                    Height="26"
                    Padding="0" 
                    BorderThickness="0" 
                    Background="Transparent"
                    Margin="2,0,0,0"
                    ToolTip="Edit">
                    <TextBlock Text="&#x270E;" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </ToggleButton>

                <Button
                    x:Name="PART_RemoveButton"
                    Grid.Column="4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Command="{Binding RemoveCommand}"
                    Width="26"
                    Height="26"
                    Padding="0" 
                    BorderThickness="0" 
                    Background="Transparent"
                    Margin="2,0,0,0">
                    <TextBlock Text="&#x2715;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsEditing, Converter={StaticResource BoolFalseToCollapsedConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition Height="1" />
                </Grid.RowDefinitions>

                <ui:QuickFilterMatchTypeToggleButton
                    FilterMatchType="{Binding MatchType, Mode=TwoWay}"
                    Margin="0,8,0,8" />

                <StackPanel Grid.Row="1" Margin="0,4,0,8">
                    <TextBlock Text="Filter Mode:" Margin="0,0,0,4" FontSize="11" Foreground="#444444"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource VisibleRadioButton}"
                                     Content="Hide non-matching lines"
                                     IsChecked="{Binding IsHighlightOnly, Converter={StaticResource InvertBoolConverter}}"
                                     Margin="0,0,16,0"/>
                        <RadioButton Style="{StaticResource VisibleRadioButton}"
                                     Content="Highlight matching lines"
                                     IsChecked="{Binding IsHighlightOnly}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,4,0,8" x:Name="ColorPickerPanel">
                    <TextBlock Text="Highlight Color:" Margin="0,0,0,4" FontSize="11" Foreground="#444444"/>
                    <tailviewerControls:SimpleColorPicker SelectedColor="{Binding DataContext.HighlightColor, ElementName=ColorPickerPanel, Mode=TwoWay}"/>
                </StackPanel>

                <Rectangle Fill="{StaticResource SeparatorBrush}" Grid.Row="4" />
            </Grid>
        </Grid>
    </DataTemplate>

</ResourceDictionary>
