<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Tailviewer.Ui"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Custom RadioButton style with always-visible circles -->
    <Style x:Key="VisibleRadioButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#666666"/>
        <Setter Property="Padding" Value="8,0,0,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Radio Circle -->
                        <Grid Width="18" Height="18" VerticalAlignment="Center">
                            <!-- Outer circle (always visible) -->
                            <Ellipse x:Name="OuterCircle"
                                     Width="18" Height="18"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="2"
                                     Fill="Transparent"/>
                            <!-- Inner circle (visible when checked) -->
                            <Ellipse x:Name="InnerCircle"
                                     Width="10" Height="10"
                                     Fill="{TemplateBinding BorderBrush}"
                                     Opacity="0"/>
                        </Grid>
                        
                        <!-- Content -->
                        <ContentPresenter Grid.Column="1"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="Left"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Grid>
                    
                    <ControlTemplate.Triggers>
                        <!-- Checked state -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="InnerCircle" Property="Opacity" Value="1"/>
                            <Setter TargetName="OuterCircle" Property="Stroke" Value="#2196F3"/>
                            <Setter TargetName="InnerCircle" Property="Fill" Value="#2196F3"/>
                        </Trigger>
                        <!-- Hover state -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterCircle" Property="Stroke" Value="#2196F3"/>
                        </Trigger>
                        <!-- Disabled state -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:QuickFilterMatchTypeToggleButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:QuickFilterMatchTypeToggleButton}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>

                            <RadioButton
                                Style="{StaticResource VisibleRadioButton}"
                                IsChecked="{Binding IsStringChecked, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Content="String"
                                GroupName="MatchType"
                                Margin="0,0,12,0" />
                            <RadioButton
                                Style="{StaticResource VisibleRadioButton}"
                                IsChecked="{Binding IsWildcardChecked, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Content="Wildcard"
                                Grid.Column="1"
                                GroupName="MatchType"
                                Margin="0,0,12,0" />
                            <RadioButton
                                Style="{StaticResource VisibleRadioButton}"
                                IsChecked="{Binding IsRegexChecked, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Content="Regexp"
                                Grid.Column="2"
                                GroupName="MatchType" />

                        </Grid>

                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
