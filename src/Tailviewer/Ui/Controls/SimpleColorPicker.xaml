<UserControl x:Class="Tailviewer.Ui.Controls.SimpleColorPicker"
             x:Name="ColorPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="200">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="Auto"/>
		</Grid.ColumnDefinitions>

		<!-- Color preview box -->
		<Border Grid.Column="0"
		        Width="24"
		        Height="24"
		        BorderBrush="Gray"
		        BorderThickness="1"
		        Margin="0,0,4,0"
		        Background="{Binding SelectedColorBrush}"
		        ToolTip="Click to change color"/>

		<!-- Preset color buttons -->
		<ItemsControl Grid.Column="1" ItemsSource="{Binding PresetColors}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<WrapPanel Orientation="Horizontal"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<Button Width="20"
					        Height="20"
					        Margin="2"
					        Background="{Binding Brush}"
					        BorderBrush="Gray"
					        BorderThickness="1"
					        Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
					        CommandParameter="{Binding Color}"
					        ToolTip="{Binding Name}"/>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<!-- Clear color button -->
		<Button Grid.Column="2"
		        Content="×"
		        Width="24"
		        Height="24"
		        Margin="4,0,0,0"
		        Command="{Binding ClearColorCommand}"
		        ToolTip="Remove highlight color"/>
	</Grid>
</UserControl>
