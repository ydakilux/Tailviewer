<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:Metrolib.Converters;assembly=Metrolib"
                    xmlns:converters2="clr-namespace:Tailviewer.Ui.Converters"
                    xmlns:controls="clr-namespace:Metrolib.Controls;assembly=Metrolib"
                    xmlns:quickFilters="clr-namespace:Tailviewer.Ui.SidePanel.QuickFilters"
                    xmlns:timeFilter="clr-namespace:Tailviewer.Ui.SidePanel.QuickFilters.TimeFilter">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Themes/Constants.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Ui/QuickFilter/QuickFilterDataTemplate.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
    <converters:BoolFalseToHiddenConverter x:Key="BoolFalseToHiddenConverter" />
    <converters:BoolFalseToCollapsedConverter x:Key="BoolFalseToCollapsedConverter" />
    <converters2:FilterCombineModeToOrConverter x:Key="FilterCombineModeToOrConverter" />

    <DataTemplate DataType="{x:Type quickFilters:QuickFiltersSidePanelViewModel}">
        <Border Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Quick Filters"
                               Foreground="DarkGray"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Margin="8,0,0,0" />

                    <controls:AddButton
                        Grid.Column="1"
                        Width="26"
                        Height="26"
                        ToolTip="Add new quick filter (Ctrl+Shift+N)"
                        VerticalAlignment="Center"
                        Command="{Binding AddCommand}" />

                </Grid>

                <!-- Filter Combine Mode Toggle -->
                <Border Grid.Row="1" Background="#F5F5F5" Padding="8,4" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Match:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11" Foreground="DarkGray" />
                        <controls:FlatToggleButton 
                            IsChecked="{Binding FilterCombineMode, Converter={StaticResource FilterCombineModeToOrConverter}}"
                            ToolTip="Toggle between AND (all filters must match) and OR (any filter can match) mode"
                            Padding="8,2"
                            FontSize="11">
                            <controls:FlatToggleButton.Style>
                                <Style TargetType="controls:FlatToggleButton">
                                    <Setter Property="Content" Value="ALL (AND)" />
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Content" Value="ANY (OR)" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:FlatToggleButton.Style>
                        </controls:FlatToggleButton>
                    </StackPanel>
                </Border>

                <timeFilter:TimeChooserControl Grid.Row="2"
                                               DataContext="{Binding TimeFilters}"/>

                <Rectangle Grid.Row="3"
                           Height="1"
                           Fill="LightGray"/>

                <controls:FlatScrollViewer
                    ScrollBarThickness="7"
                    Margin="0,8,0,0"
                    Grid.Row="4">
                    <ItemsControl
                        ItemsSource="{Binding QuickFilters}" />
                </controls:FlatScrollViewer>
            </Grid>

        </Border>
    </DataTemplate>

</ResourceDictionary>