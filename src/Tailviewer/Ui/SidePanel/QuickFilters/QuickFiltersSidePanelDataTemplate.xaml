<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters2="clr-namespace:Tailviewer.Ui.Converters"
                    xmlns:quickFilters="clr-namespace:Tailviewer.Ui.SidePanel.QuickFilters"
                    xmlns:timeFilter="clr-namespace:Tailviewer.Ui.SidePanel.QuickFilters.TimeFilter">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Themes/Constants.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Themes/Converters.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Tailviewer;component/Ui/QuickFilter/QuickFilterDataTemplate.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <converters2:FilterCombineModeToOrConverter x:Key="FilterCombineModeToOrConverter" />

    <DataTemplate DataType="{x:Type quickFilters:QuickFiltersSidePanelViewModel}">
        <Border Background="White" TextElement.Foreground="Black">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <!-- Header: Title + Add Button -->
                <Grid Margin="8,8,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Quick Filters"
                               Foreground="#333333"
                               VerticalAlignment="Center"
                               FontSize="14"
                               FontWeight="SemiBold"/>

                    <Button
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        ToolTip="Add new quick filter (Ctrl+Shift+N)"
                        VerticalAlignment="Center"
                        Command="{Binding AddCommand}"
                        Margin="8,0,0,0"
                        Padding="0" 
                        BorderThickness="0" 
                        Background="#2196F3"
                        Foreground="White"
                        Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="14"
                                                    BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1E88E5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="+" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>

                </Grid>

                <!-- Match Mode: AND/OR Toggle -->
                <Border Grid.Row="1" Background="#F5F5F5" Padding="8,8" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Match:" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,8,0" 
                                   FontSize="11" 
                                   Foreground="#666666"
                                   FontWeight="Medium"/>
                        <ToggleButton
                            IsChecked="{Binding FilterCombineMode, Converter={StaticResource FilterCombineModeToOrConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="True"
                            ToolTip="Toggle between AND (all filters must match) and OR (any filter can match) mode"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Width="44"
                            Height="22"
                            Cursor="Hand"
                            Focusable="True">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Grid>
                                                    <Border x:Name="TrackBorder" 
                                                            Width="44" 
                                                            Height="22"
                                                            CornerRadius="11"
                                                            Background="#BDBDBD"
                                                            BorderBrush="#9E9E9E"
                                                            BorderThickness="1">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#000000" 
                                                                            Opacity="0.1" 
                                                                            BlurRadius="2" 
                                                                            ShadowDepth="1" 
                                                                            Direction="270"/>
                                                        </Border.Effect>
                                                    </Border>
                                                    <Ellipse x:Name="ThumbEllipse"
                                                             Width="18" 
                                                             Height="18"
                                                             Fill="White"
                                                             HorizontalAlignment="Left"
                                                             Margin="2,0,0,0"
                                                             Stroke="#9E9E9E"
                                                             StrokeThickness="1">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect Color="#000000" 
                                                                            Opacity="0.3" 
                                                                            BlurRadius="4" 
                                                                            ShadowDepth="2" 
                                                                            Direction="270"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="TrackBorder" Property="Background" Value="#2196F3"/>
                                                        <Setter TargetName="TrackBorder" Property="BorderBrush" Value="#1976D2"/>
                                                        <Setter TargetName="ThumbEllipse" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="ThumbEllipse" Property="Margin" Value="0,0,2,0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbEllipse" Property="Fill" Value="#F5F5F5"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsChecked" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="TrackBorder" Property="Background" Value="#A0A0A0"/>
                                                    </MultiTrigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsChecked" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="TrackBorder" Property="Background" Value="#1E88E5"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <TextBlock VerticalAlignment="Center" 
                                   FontSize="11"
                                   FontWeight="Medium"
                                   Margin="0,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="ALL (AND)" />
                                    <Setter Property="Foreground" Value="#333333" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterCombineMode, Converter={StaticResource FilterCombineModeToOrConverter}}" Value="True">
                                            <Setter Property="Text" Value="ANY (OR)" />
                                            <Setter Property="Foreground" Value="#2196F3" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Time Range Filter (Everything/Quick/Absolute) -->
                <timeFilter:TimeChooserControl Grid.Row="2"
                                               DataContext="{Binding TimeFilters}"
                                               Margin="0,8,0,0"/>

                <!-- Separator -->
                <Rectangle Grid.Row="3"
                           Height="1"
                           Fill="#E0E0E0"
                           Margin="0,8,0,0"/>

                <ScrollViewer
                    Margin="0,8,0,0"
                    Grid.Row="4">
                    <!-- DEBUG: Test if this area renders -->
                    <StackPanel>
                        <TextBlock Text="DEBUG: Filters go here" Foreground="Red" FontSize="12" Margin="8"/>
                        <ItemsControl ItemsSource="{Binding QuickFilters}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
