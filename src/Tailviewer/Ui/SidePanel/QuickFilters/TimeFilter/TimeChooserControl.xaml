<UserControl x:Class="Tailviewer.Ui.SidePanel.QuickFilters.TimeFilter.TimeChooserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:Tailviewer.Ui.Converters"
             xmlns:timeFilter="clr-namespace:Tailviewer.Ui.SidePanel.QuickFilters.TimeFilter"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance timeFilter:TimeFiltersViewModel}">

    <UserControl.Resources>
        <converters:BoolFalseToCollapsedConverter x:Key="BoolFalseToCollapsedConverter" />
        <converters:BoolTrueToHiddenConverter x:Key="BoolTrueToHiddenConverter" />
        
        <!-- Pill-style toggle button for time filters -->
        <Style x:Key="PillToggleButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border"
                                Background="#E0E0E0"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14,6"
                                Margin="2,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            TextElement.Foreground="#333333"
                                            TextElement.FontSize="12"
                                            TextElement.FontWeight="Medium"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2196F3" />
                                <Setter TargetName="Border" Property="TextElement.Foreground" Value="White" />
                            </Trigger>
                            <!-- Hover effect for unchecked state -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#D0D0D0"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#1E88E5"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Time Filter Mode Pills -->
        <Border Background="#F5F5F5" Padding="8,8" Margin="0,4,0,0">
            <StackPanel>
                <TextBlock Text="Time Range:" 
                           FontSize="11" 
                           Foreground="#666666" 
                           Margin="0,0,0,6"
                           FontWeight="Medium"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <RadioButton Style="{StaticResource PillToggleButton}"
                                 Content="Everything"
                                 GroupName="TimeFilter"
                                 IsChecked="{Binding SelectEverything, Mode=TwoWay}"
                                 ToolTip="Show all log entries regardless of time"/>
                    
                    <RadioButton Style="{StaticResource PillToggleButton}"
                                 Content="Quick"
                                 GroupName="TimeFilter"
                                 IsChecked="{Binding SelectBySpecialInterval, Mode=TwoWay}"
                                 ToolTip="Filter by common time ranges (today, this week, etc.)"/>
                    
                    <RadioButton Style="{StaticResource PillToggleButton}"
                                 Content="Absolute"
                                 GroupName="TimeFilter"
                                 IsChecked="{Binding SelectByInterval, Mode=TwoWay}"
                                 ToolTip="Filter by specific date range"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Quick Range Picker -->
        <Border Grid.Row="1"
                Background="White"
                Padding="8"
                Margin="0,0,0,4"
                Visibility="{Binding SelectBySpecialInterval, Converter={StaticResource BoolFalseToCollapsedConverter}}">
            <StackPanel>
                <TextBlock Text="Select range:" 
                           FontSize="11" 
                           Foreground="#666666" 
                           Margin="0,0,0,4"/>
                <ListBox ItemsSource="{Binding AvailableSpecialRanges}"
                         SelectedItem="{Binding SelectedSpecialInterval, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="Margin" Value="0,1"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type timeFilter:SpecialTimeRangeViewModel}">
                            <TextBlock Text="{Binding Title}" 
                                       FontSize="12"
                                       Foreground="#333333"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Absolute Date Range Picker -->
        <Border Grid.Row="1"
                Background="White"
                Padding="8"
                Margin="0,0,0,4"
                Visibility="{Binding SelectByInterval, Converter={StaticResource BoolFalseToCollapsedConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="From:"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#333333"
                           Margin="0,0,8,0"/>
                <DatePicker Grid.Column="1"
                            Margin="0,4"
                            SelectedDate="{Binding Minimum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                
                <TextBlock Grid.Row="1"
                           Text="To:"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#333333"
                           Margin="0,0,8,0"/>
                <DatePicker Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,4"
                            SelectedDate="{Binding Maximum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
