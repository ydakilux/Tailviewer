<UserControl x:Class="Tailviewer.Ui.LogView.JsonDetailsFlyoutControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:converters="clr-namespace:Metrolib.Converters;assembly=Metrolib"
             Focusable="True"
             Loaded="OnLoaded">

	<UserControl.Resources>
		<converters:BoolFalseToCollapsedConverter x:Key="BoolFalseToCollapsedConverter" />
		<converters:BoolTrueToCollapsedConverter x:Key="BoolTrueToCollapsedConverter" />
	</UserControl.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Header with metadata -->
		<StackPanel Grid.Row="0" Margin="0,0,0,16">
			<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
				<TextBlock Text="Line: " FontWeight="Bold" Foreground="#666" />
				<TextBlock Text="{Binding LineNumber}" Foreground="#333" />
				<TextBlock Text="  |  " Margin="8,0" Foreground="#999" />
				<TextBlock Text="Timestamp: " FontWeight="Bold" Foreground="#666" />
				<TextBlock Text="{Binding Timestamp}" Foreground="#333" />
				<TextBlock Text="  |  " Margin="8,0" Foreground="#999" />
				<TextBlock Text="Level: " FontWeight="Bold" Foreground="#666" />
				<TextBlock Text="{Binding LogLevel}" Foreground="#333" />
			</StackPanel>

			<!-- JSON validation status -->
			<Border Background="#f0f0f0" Padding="8" CornerRadius="4"
			        Visibility="{Binding IsValidJson, Converter={StaticResource BoolFalseToCollapsedConverter}}">
				<StackPanel Orientation="Horizontal">
					<TextBlock Text="✓" FontSize="16" Foreground="Green" Margin="0,0,8,0" />
					<TextBlock Text="Valid JSON" FontWeight="Bold" Foreground="Green" />
					<TextBlock Text="  (Press CTRL+F to search)" FontSize="10" Foreground="#666" Margin="8,0,0,0" VerticalAlignment="Center" />
				</StackPanel>
			</Border>

			<Border Background="#ffe0e0" Padding="8" CornerRadius="4"
			        Visibility="{Binding IsValidJson, Converter={StaticResource BoolTrueToCollapsedConverter}}">
				<StackPanel>
					<StackPanel Orientation="Horizontal" Margin="0,0,0,4">
						<TextBlock Text="✗" FontSize="16" Foreground="Red" Margin="0,0,8,0" />
						<TextBlock Text="Not valid JSON" FontWeight="Bold" Foreground="Red" />
					</StackPanel>
					<TextBlock Text="{Binding ErrorMessage}" Foreground="#666" TextWrapping="Wrap" />
				</StackPanel>
			</Border>
		</StackPanel>

		<!-- Content area with AvalonEdit for syntax highlighting and search -->
		<Border Grid.Row="1" 
		        BorderBrush="#ccc" 
		        BorderThickness="1" 
		        Background="White"
		        CornerRadius="4">
			<avalon:TextEditor x:Name="JsonEditor"
			                   Document="{Binding JsonDocument}"
			                   IsReadOnly="True"
			                   ShowLineNumbers="True"
			                   FontFamily="Consolas"
			                   FontSize="12"
			                   Padding="4"
			                   WordWrap="False"
			                   VerticalScrollBarVisibility="Auto"
			                   HorizontalScrollBarVisibility="Auto"
			                   Background="White"
			                   Foreground="Black" />
		</Border>
	</Grid>

</UserControl>
