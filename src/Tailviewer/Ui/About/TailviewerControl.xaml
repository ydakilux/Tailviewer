<UserControl x:Class="Tailviewer.Ui.About.TailviewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:tailviewer="clr-namespace:Tailviewer"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid HorizontalAlignment="Center" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock Text="Tailviewer"
                   FontSize="32" />
        <StackPanel Orientation="Horizontal" Grid.Row="1">
            <TextBlock>
                <Hyperlink NavigateUri="{x:Static tailviewer:Constants.ProjectPage}" RequestNavigate="OnRequestNavigate">
                    <Run Text="Website" />
                </Hyperlink>
            </TextBlock>
            <TextBlock Margin="8,0,0,0">
                <Hyperlink NavigateUri="{x:Static tailviewer:Constants.GithubPage}" RequestNavigate="OnRequestNavigate">
                    <Run Text="Source" />
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <ScrollViewer Grid.Row="2">
            <TextBlock Text="{x:Static tailviewer:Constants.ApplicationLicense}"
                       Margin="0,8,0,0" />
        </ScrollViewer>
    </Grid>
</UserControl>
